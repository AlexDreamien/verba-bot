# Telegram bot token obtained from @BotFather
BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to run /broadcast (admins).
# Find your ID via @userinfobot. Example: ADMIN_IDS=12345678,87654321
ADMIN_IDS=

# Public HTTPS URL of the deployed Mini App (the webapp/ folder).
# Registered as the Mini App / menu-button URL in @BotFather.
# Example: https://alexdreamien.github.io/verba-bot/
WEBAPP_URL=

# Path to the SQLite database file
DB_PATH=verba.db

# Host/port the aiohttp result-collector listens on (behind an HTTPS proxy).
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Max age (seconds) of a Telegram initData signature before it is rejected.
INIT_DATA_MAX_AGE=86400

# IANA timezone used for the daily word rollover and schedules (the game uses Kyiv).
TZ=Europe/Kyiv

# Cron expression (in TZ) for the automatic daily broadcast. Empty = disabled.
# Example: "0 9 * * *" sends every day at 09:00 local time.
BROADCAST_CRON=0 9 * * *

# Time of day (HH:MM in TZ) when the day is closed: unfinished players are
# recorded and the daily summary is posted. Should be just before midnight.
CLOSE_DAY_AT=23:59

# Optional: post the end-of-day summary to subscribers (1) or only to admins (0).
SUMMARY_TO_SUBSCRIBERS=0
